# Copy to .env and fill in. Never commit real values.

# Base directory of the Obsidian vault / tree to scan.
OBSIDIAN_BASE_DIR=/path/to/your/obsidian/vault

# LM Studio server (host:port for the lmstudio python SDK, no scheme, no /v1).
LMSTUDIO_HOST=localhost:1234
LMSTUDIO_MODEL=qwen/qwen3-vl-8b

# Max tokens generated per image/PDF page. Caps runaway generation so one bad scan
# can't hang the run. Raise if dense pages get truncated.
LMSTUDIO_MAX_TOKENS=4096
